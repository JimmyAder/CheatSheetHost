      "title": "TRIAGE QUESTIONS FOR A SUSPICIOUS LOOP",
      "items": [
        {
          "key": "What is the unit?",
          "value": "Byte, word, dword, block?"
        },
        {
          "key": "What is the state?",
          "value": "Single accumulator, multiple accumulators, key buffer?"
        },
        {
          "key": "What constants repeat?",
          "value": "Primes, deltas, masks, alphabet sizes, round counts?"
        },
        {
          "key": "Is there a table?",
          "value": "S-box, CRC table, alphabet, reverse lookup?"
        },
        {
          "key": "Is it reversible?",
          "value": "XOR and some rotates often are; hashes usually are not"
        },
        {
          "key": "Where is output used?",
          "value": "Comparison, decode, file write, network send, next stage?"
