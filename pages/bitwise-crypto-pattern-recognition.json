          "value": "Simple XOR encoding/decoding"
        },
        {
          "key": "buf[i] ^ key[i % n]",
          "value": "Repeating-key XOR"
        },
        {
          "key": "buf[i] ^ i",
          "value": "Index-dependent obfuscation"
        },
        {
          "key": "XOR is reversible",
          "value": "Same operation often decodes and encodes"
