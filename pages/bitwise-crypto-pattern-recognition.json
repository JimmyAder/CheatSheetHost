{
  "slug": "bitwise-crypto-pattern-recognition",
  "title": "Bitwise / Crypto Pattern Recognition",
  "subtitle": "Reference sheet for spotting common bitwise operations, encoders, hashes, and crypto-related patterns during reverse engineering.",
  "sections": [
    {
      "type": "text",
      "title": "How to Use This Sheet",
      "text": "This sheet is for pattern recognition, not just definitions. When reversing, the main goal is to quickly identify what a loop or function is probably doing. Look for repeated constants, loop shapes, shifts/rotates, XORs, table lookups, byte swapping, and accumulator updates. Use this as a mental checklist when a function looks like decoding, hashing, packing, encryption, or bitfield handling."
    },
    {
      "type": "table",
      "title": "CORE BITWISE OPERATIONS",
      "items": [
        {
          "key": "AND",
          "value": "Mask bits, test flags, keep selected bits"
        },
        {
          "key": "OR",
          "value": "Set bits, combine flags"
        },
        {
          "key": "XOR",
          "value": "Toggle bits, reversible transform, zeroing idiom"
        },
        {
          "key": "NOT",
          "value": "Invert bits"
        },
        {
          "key": "SHL / SAL",
          "value": "Left shift, multiply by powers of two"
        },
        {
          "key": "SHR",
          "value": "Logical right shift, unsigned divide by powers of two"
        },
        {
          "key": "SAR",
          "value": "Arithmetic right shift, signed divide by powers of two"
        },
        {
          "key": "ROL / ROR",
          "value": "Rotate bits; very common in hashes and custom ciphers"
        },
        {
          "key": "RCL / RCR",
          "value": "Rotate through carry"
        },
        {
          "key": "TEST",
          "value": "AND for flags only; common for flag checks"
        }
      ]
    },
    {
      "type": "table",
      "title": "COMMON BIT-MASK PATTERNS",
      "items": [
        {
          "key": "x & 1",
          "value": "Check lowest bit"
        },
        {
          "key": "(x >> n) & 1",
          "value": "Check bit n"
        },
        {
          "key": "x & 0xFF",
          "value": "Keep low byte"
        },
        {
          "key": "x & 0xFFFF",
          "value": "Keep low 16 bits"
        },
        {
          "key": "x | (1 << n)",
          "value": "Set bit n"
        },
        {
          "key": "x & ~(1 << n)",
          "value": "Clear bit n"
        },
        {
          "key": "x ^ (1 << n)",
          "value": "Toggle bit n"
        },
        {
          "key": "x & (x - 1)",
          "value": "Clear lowest set bit"
        },
        {
          "key": "x & -x",
          "value": "Isolate lowest set bit"
        }
      ]
    },
    {
      "type": "table",
