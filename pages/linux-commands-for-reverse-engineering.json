{
  "slug": "linux-commands-for-reverse-engineering",
  "title": "Helpful Linux Commands for Reverse Engineering",
  "subtitle": "Common Linux command-line tools that are available on many systems and are useful for triage, binary inspection, debugging, tracing, and file analysis.",
  "sections": [
    {
      "type": "text",
      "title": "Scope",
      "text": "This sheet focuses on commands that are commonly available on many Linux installations or are very commonly installed in RE, CTF, and systems environments. The goal is fast triage and practical workflow support: identify files, inspect strings, search bytes, trace behavior, compare outputs, and understand what a binary is doing."
    },
    {
      "type": "table",
      "title": "FAST TRIAGE COMMANDS",
      "items": [
        {
          "key": "file target",
          "value": "Identify file type, architecture, endianness, stripping, etc."
        },
        {
          "key": "ls -l",
          "value": "Quick file size, perms, timestamps"
        },
        {
          "key": "stat target",
          "value": "Detailed metadata"
        },
        {
          "key": "sha256sum target",
          "value": "Fingerprint sample or verify integrity"
        },
        {
          "key": "md5sum target",
          "value": "Legacy quick hash reference"
        },
        {
          "key": "wc -c target",
          "value": "Byte size"
        },
        {
          "key": "uname -a",
          "value": "Host/kernel info for environment context"
        }
      ]
    },
    {
      "type": "table",
      "title": "STRING / TEXT DISCOVERY",
      "items": [
        {
          "key": "strings target",
          "value": "Extract printable strings"
        },
        {
          "key": "strings -a target",
          "value": "Scan whole file, not just loaded sections"
        },
        {
          "key": "strings -n 4 target",
          "value": "Minimum string length 4"
        },
        {
          "key": "strings target | grep key",
          "value": "Search strings for keywords"
        },
        {
          "key": "grep -R pattern dir/",
          "value": "Recursive text search"
        },
        {
          "key": "grep -a pattern target",
          "value": "Treat binary as text for rough searching"
        },
        {
          "key": "grep -oba 'MZ' target",
          "value": "Find byte/text pattern offsets"
        }
      ]
    },
    {
      "type": "table",
      "title": "HEX / BINARY VIEWING",
      "items": [
        {
          "key": "xxd target | less",
          "value": "Hex dump with ASCII"
        },
        {
          "key": "xxd -g 1 target",
          "value": "Group by single bytes"
        },
        {
          "key": "xxd -s 0x100 -l 0x80 target",
          "value": "Dump region at offset"
        },
        {
          "key": "hexdump -C target",
          "value": "Classic canonical hex+ASCII dump"
        },
        {
          "key": "od -Ax -tx1z target",
          "value": "Hex/ASCII dump alternative"
        },
        {
          "key": "cmp a b",
          "value": "Compare two files byte-by-byte"
        },
        {
          "key": "diff -u a b",
          "value": "Text diff, useful for decoded outputs"
        }
      ]
    },
    {
      "type": "table",
      "title": "ELF / BINARY INSPECTION",
      "items": [
        {
          "key": "readelf -h target",
          "value": "ELF header"
        },
        {
          "key": "readelf -S target",
          "value": "ELF sections"
        },
        {
          "key": "readelf -l target",
          "value": "Program headers / segments"
        },
        {
          "key": "readelf -s target",
          "value": "Symbol table"
        },
        {
          "key": "readelf -r target",
          "value": "Relocations"
