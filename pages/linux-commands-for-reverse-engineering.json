        {
          "key": "ltrace ./target",
          "value": "Trace library calls (if installed)"
        },
        {
          "key": "time ./target",
          "value": "Measure runtime quickly"
        },
        {
          "key": "timeout 5 ./target",
          "value": "Kill long-running target after 5 sec"
        }
