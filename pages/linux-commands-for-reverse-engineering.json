    {
      "type": "table",
      "title": "VERY COMMON WORKFLOW COMBINATIONS",
      "items": [
        {
          "key": "file + strings + readelf",
          "value": "Fast ELF triage trio"
        },
        {
          "key": "strings | grep",
          "value": "Find commands, messages, file paths, URLs"
