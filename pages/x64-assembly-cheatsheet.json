{
  "slug": "x64-assembly-cheatsheet",
  "title": "x64 Assembly Cheat Sheet",
  "subtitle": "Comprehensive x64 assembly reference for reverse engineering, debugging, and low-level programming.",
  "sections": [
    {
      "type": "text",
      "title": "Scope",
      "text": "This sheet focuses on x86-64 / AMD64 concepts used in reverse engineering, debugging, crackmes, malware analysis, and low-level systems work. It mixes generic x64 concepts with Linux SysV and Windows x64 calling convention notes where useful."
    },
    {
      "type": "table",
      "title": "GENERAL PURPOSE REGISTERS",
