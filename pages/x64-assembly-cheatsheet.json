        {
          "key": "RAX",
          "value": "Accumulator, return value, syscall number on Linux"
        },
        {
          "key": "RBX",
          "value": "Callee-saved general register"
        },
        {
          "key": "RCX",
          "value": "Counter, shift count, 4th arg in SysV, 1st arg in Win64"
        },
        {
          "key": "RDX",
          "value": "Data register, 3rd arg in SysV, 2nd arg in Win64"
        },
        {
          "key": "RSI",
          "value": "Source index, 2nd arg in SysV"
        },
        {
          "key": "RDI",
          "value": "Destination index, 1st arg in SysV"
        },
        {
          "key": "RBP",
