    {
      "type": "table",
      "title": "WHEN TO CREATE A STRUCT",
      "items": [
        {
          "key": "Repeated offsets",
          "value": "Same register + many fixed offsets"
        },
        {
          "key": "Known layouts",
          "value": "Headers, packets, PEB/TEB, object instances"
        },
        {
          "key": "Mixed widths",
          "value": "1/2/4/8-byte fields with stable ordering"
        },
        {
          "key": "Pointer clusters",
          "value": "Object- or context-like memory"
        },
        {
          "key": "Looped field access",
          "value": "Parser or serializer over field layout"
        }
      ]
    },
    {
      "type": "table",
      "title": "DECOMPILER PITFALLS",
      "items": [
        {
          "key": "Signed vs unsigned",
          "value": "Verify comparisons and extensions in disassembly"
        },
        {
          "key": "Bit masks / rotates",
          "value": "Decompiler can obscure low-level intent"
        },
        {
          "key": "Pointer aliasing",
          "value": "Type guesses can become misleading"
        },
        {
          "key": "Switch recovery",
          "value": "Confirm jump table targets manually if odd"
        },
        {
          "key": "Stack vars",
          "value": "Frame recovery can create weird pseudo-locals"
        },
        {
          "key": "Optimized code",
          "value": "Compiler transforms may distort original structure"
        }
      ]
    },
