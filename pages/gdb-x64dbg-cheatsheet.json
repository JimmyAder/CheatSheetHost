      "title": "BREAKPOINTS: WHAT REGISTERS TO CHECK",
      "items": [
        {
          "key": "strcmp (Linux x64)",
          "value": "RDI = first string, RSI = second string"
        },
        {
          "key": "strncmp (Linux x64)",
          "value": "RDI = first string, RSI = second string, RDX = length"
        },
        {
          "key": "memcmp (Linux x64)",
          "value": "RDI = first buffer, RSI = second buffer, RDX = length"
        },
        {
          "key": "strlen (Linux x64)",
          "value": "RDI = string pointer"
        },
        {
          "key": "puts (Linux x64)",
          "value": "RDI = string pointer being printed"
        },
        {
          "key": "read (Linux x64 libc wrapper)",
          "value": "RDI = fd, RSI = buffer, RDX = count"
        },
        {
          "key": "Win64 reminder",
          "value": "RCX, RDX, R8, R9 usually hold first four args"
        },
